{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "lib": ["ES2022"],
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "target": "ES2022",
        "outDir": "dist",
        "rootDir": "src",
        "types": ["node", "vitest/globals"],
        "noEmit": true
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist"]
}
